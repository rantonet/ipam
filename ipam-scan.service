[Unit]
Description=IPAM Nightly Network Scan
After=network.target ipam.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/html/ipam
Environment="PATH=/usr/local/bin:/usr/bin"
Environment="IPAM_SEED=0"
ExecStart=/usr/bin/python3 /var/www/html/ipam/scanner.py --all --skip-recent 6
StandardOutput=journal
StandardError=journal
